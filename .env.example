# Database (not exposed to host — only accessible within Docker network)
DB_NAME=goac
DB_USER=goac
DB_PASSWORD=CHANGE_ME

# Auth secrets (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SendGrid (optional — emails are logged when not set)
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=meetings@yourdomain.com

# S3 Storage (Hetzner Object Storage — optional)
S3_ENDPOINT_URL=https://your-bucket.s3.eu-central.hetzner.cloud
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=assetmeetinghelper
S3_REGION=eu-central

# Frontend URLs (must match your domain)
NEXT_PUBLIC_API_URL=https://assetmeeting.goac.io/api/v1
NEXTAUTH_URL=https://assetmeeting.goac.io
